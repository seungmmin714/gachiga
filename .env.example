POSTGRES_USER=gachiga
POSTGRES_PASSWORD=gachiga
POSTGRES_DB=gachiga

DATABASE_URL=postgresql+psycopg2://gachiga:gachiga@db:5432/gachiga
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=changeme
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=20160

# 전화번호 암호화용 Fernet 키 (비우면 JWT_SECRET_KEY에서 파생)
PHONE_ENC_KEY=

# Sentry 에러 트래킹 (비우면 비활성)
SENTRY_DSN=

# 매칭 엔진 파라미터
MATCHING_LOOP_ENABLED=true
MATCH_INTERVAL_SECONDS=30
MATCH_ORIGIN_EPS_KM=0.8
MATCH_DEST_EPS_KM=0.8
MATCH_MAX_GROUP=3
MATCH_MAX_DETOUR=1.3
MATCH_MIN_OVERLAP_MIN=5
